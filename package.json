{
  "name": "hotel-project-workspace",
  "private": true,
  "version": "1.0.0",
  "description": "Workspace scripts for frontend/backend hotel-project",
  "scripts": {
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "start:backend": "npm --prefix backend start",
    "build:frontend": "npm --prefix frontend run build",
    "check:frontend": "npm --prefix frontend run build",
    "check:backend": "node scripts/check-api.js",
    "test:reservation": "node scripts/e2e-reservation-test.js",
    "test:guest-booking": "node scripts/e2e-guest-booking-test.js",
    "verify": "npm run check:frontend && npm run check:backend"
  }
}
